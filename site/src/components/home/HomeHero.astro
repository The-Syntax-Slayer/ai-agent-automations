---
import type { SiteConfig } from '../../data/site';

type Props = {
  site: SiteConfig;
};

const { site } = Astro.props;
---

<header class="hero">
  <div class="hero-copy">
    <div class="kicker mono">{site.heroKicker}</div>
    <h1 class="title-boxed">
      {site.heroTitlePrefix} <span class="invert">{site.heroTitleAccent}</span> {site.heroTitleSuffix}
    </h1>
    <p class="subtitle">{site.description}</p>

    <div class="agent-strip" aria-label="Works with Codex, Claude, and Cursor">
      <div class="agent-strip-label mono">{site.worksWithLabel}</div>
      <div class="agent-list" role="list">
        {
          site.logos.map((logo) => (
            <span class="agent-logo-wrap" role="listitem">
              <img class:list={['agent-logo', logo.className]} src={logo.src} alt={logo.alt} loading="lazy" />
            </span>
          ))
        }
      </div>
    </div>

    <a class="repo-callout" href={site.repoUrl} target="_blank" rel="noreferrer">
      <span class="repo-icon" aria-hidden="true">
        <svg viewBox="0 0 16 16" width="15" height="15">
          <path
            fill="currentColor"
            d="M8 0C3.58 0 0 3.64 0 8.13c0 3.59 2.29 6.63 5.47 7.71.4.08.55-.18.55-.39 0-.19-.01-.83-.01-1.51-2.01.38-2.53-.5-2.69-.96-.09-.24-.48-.96-.82-1.15-.28-.15-.68-.52-.01-.53.63-.01 1.08.59 1.23.83.72 1.23 1.87.88 2.33.67.07-.53.28-.88.51-1.08-1.78-.21-3.64-.91-3.64-4.03 0-.89.31-1.62.82-2.19-.08-.21-.36-1.04.08-2.16 0 0 .67-.22 2.2.84A7.45 7.45 0 0 1 8 3.91c.68 0 1.36.09 2 .27 1.53-1.06 2.2-.84 2.2-.84.44 1.12.16 1.95.08 2.16.51.57.82 1.3.82 2.19 0 3.13-1.87 3.82-3.65 4.03.29.25.54.75.54 1.52 0 1.1-.01 1.98-.01 2.25 0 .21.15.47.55.39A8.02 8.02 0 0 0 16 8.13C16 3.64 12.42 0 8 0Z"
          ></path>
        </svg>
      </span>
      <span class="repo-text">
        <span class="repo-kicker mono">{site.repoKicker}</span>
        <span class="repo-name mono">{site.repoName}</span>
      </span>
      <span class="repo-star mono">{site.repoCta}</span>
    </a>
  </div>

  <div class="header-art" aria-hidden="true">
    <video autoplay loop muted playsinline preload="auto">
      <source src={site.heroVideoSrc} type="video/webm" />
    </video>
  </div>
</header>
